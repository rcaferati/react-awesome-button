exports[`Public API smoke tests renders AwesomeButton with before/after slots 1`] = `
<button
  className="aws-btn aws-btn--auto aws-btn--primary aws-btn--visible aws-btn--animate-size"
  disabled={false}
  onClick={[Function]}
  onKeyDown={[Function]}
  onKeyUp={[Function]}
  onMouseEnter={[Function]}
  onPointerCancel={[Function]}
  onPointerDown={[Function]}
  onPointerLeave={[Function]}
  onPointerMove={[Function]}
  onPointerUp={[Function]}
  style={{}}
  type="button"
>
  <span
    className="aws-btn__wrapper"
  >
    <span
      className="aws-btn__content"
      data-aws-btn-role="content"
    >
      <span
        className="aws-btn__slot aws-btn__slot--before"
      >
        <span
          aria-hidden="true"
        >
          ←
        </span>
      </span>
      <span
        className="aws-btn__label"
        data-aws-btn-role="label"
      >
        Continue
      </span>
      <span
        className="aws-btn__slot aws-btn__slot--after"
      >
        <span
          aria-hidden="true"
        >
          →
        </span>
      </span>
    </span>
  </span>
</button>
`;

