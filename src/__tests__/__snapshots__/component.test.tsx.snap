exports[`Public API smoke tests renders AwesomeButtonProgress without crashing 1`] = `
<button
  className="aws-btn aws-btn--auto aws-btn--visible aws-btn--animate-size aws-btn--progress"
  disabled={false}
  onClick={[Function]}
  onKeyDown={[Function]}
  onKeyUp={[Function]}
  onMouseEnter={[Function]}
  onPointerCancel={[Function]}
  onPointerDown={[Function]}
  onPointerLeave={[Function]}
  onPointerMove={[Function]}
  onPointerUp={[Function]}
  style={
    {
      "--loading-transition-end-speed": "300ms",
      "--loading-transition-speed": "6000ms",
    }
  }
  type="button"
>
  <span
    className="aws-btn__wrapper"
  >
    <span
      className="aws-btn__content"
      data-aws-btn-role="content"
    >
      <span
        className="aws-btn__label"
        data-aws-btn-role="label"
      >
        <span />
      </span>
    </span>
    <span
      className="aws-btn__extra"
    >
      <span>
        <span
          className="aws-btn__progress"
          data-loading="Wait.."
          data-status="Success!"
        />
      </span>
    </span>
  </span>
</button>
`;

